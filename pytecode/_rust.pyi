from pathlib import Path
from typing import Any

class MalformedClassException(Exception): ...

class Utf8Info:
    @property
    def index(self) -> int: ...
    @property
    def offset(self) -> int | None: ...
    @property
    def tag(self) -> int: ...
    @property
    def length(self) -> int: ...
    @property
    def str_bytes(self) -> bytes: ...

class FieldrefInfo: ...
class MethodrefInfo: ...
class InterfaceMethodrefInfo: ...

class InsnInfo:
    @property
