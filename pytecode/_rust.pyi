CodeItem = (
    Label
    | RawInsn
    | ByteInsn
    | ShortInsn
    | NewArrayInsn
    | FieldInsn
    | MethodInsn
    | InterfaceMethodInsn
    | TypeInsn
    | VarInsn
    | IIncInsn
    | LdcInsn
    | InvokeDynamicInsn
    | MultiANewArrayInsn
    | BranchInsn
    | LookupSwitchInsn
    | TableSwitchInsn
)

CodeListItem = CodeItem | ExceptionHandler | LineNumberEntry | LocalVariableEntry | LocalVariableTypeEntry

