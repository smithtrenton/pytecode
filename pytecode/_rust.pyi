class RustConstantPoolBuilder:
    def __init__(self) -> None: ...
    def add_utf8(self, value: str) -> int: ...
    def add_class(self, name: str) -> int: ...
    def add_string(self, value: str) -> int: ...
    def add_integer(self, value: int) -> int: ...
    def add_long(self, value: int) -> int: ...
    def add_float_bits(self, raw_bits: int) -> int: ...
    def add_double_bits(self, raw_bits: int) -> int: ...
    def add_field_ref(self, owner: str, name: str, descriptor: str) -> int: ...
    def add_method_ref(self, owner: str, name: str, descriptor: str) -> int: ...
    def add_interface_method_ref(self, owner: str, name: str, descriptor: str) -> int: ...
    def add_method_type(self, descriptor: str) -> int: ...
    def add_method_handle(self, reference_kind: int, reference_index: int) -> int: ...
    def add_invoke_dynamic(self, bootstrap_idx: int, name: str, descriptor: str) -> int: ...
    def resolve_utf8(self, index: int) -> str: ...
    def resolve_class_name(self, index: int) -> str: ...
    def count(self) -> int: ...
    def len(self) -> int: ...

class RustMappingClassResolver:
    def __init__(self) -> None: ...
    @staticmethod
    def from_bytes(class_bytes_list: list[bytes]) -> RustMappingClassResolver: ...
    def resolve_class(self, name: str) -> Any | None: ...

class RustClassModel:
    @staticmethod
    def from_bytes(data: bytes) -> RustClassModel: ...
    def to_bytes(self) -> bytes: ...
    def to_bytes_with_options(
        self,
        recompute_frames: bool = False,
        resolver: RustMappingClassResolver | None = None,
        debug_info: str = "preserve",
    ) -> bytes: ...
    @property
    def entry_name(self) -> str: ...
    @property
    def original_byte_len(self) -> int: ...
    @property
    def version(self) -> tuple[int, int]: ...
    @version.setter
    def version(self, value: tuple[int, int]) -> None: ...
    @property
    def access_flags(self) -> int: ...
    @access_flags.setter
    def access_flags(self, value: int) -> None: ...
    @property
    def name(self) -> str: ...
    @name.setter
    def name(self, value: str) -> None: ...
    @property
    def super_name(self) -> str | None: ...
    @super_name.setter
    def super_name(self, value: str | None) -> None: ...
    @property
    def interfaces(self) -> list[str]: ...
    @interfaces.setter
    def interfaces(self, value: list[str]) -> None: ...
    @property
    def fields(self) -> list[RustFieldModel]: ...
    @fields.setter
    def fields(self, value: list[RustFieldModel]) -> None: ...
    @property
    def methods(self) -> list[RustMethodModel]: ...
    @methods.setter
    def methods(self, value: list[RustMethodModel]) -> None: ...
    @property
    def attributes(self) -> list[Any]: ...
    @property
    def constant_pool(self) -> RustConstantPoolBuilder: ...
    @property
    def debug_info_state(self) -> str: ...

