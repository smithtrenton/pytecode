    @property
    def count(self) -> int | None: ...
    @property
    def reserved(self) -> bytes | None: ...
    @property
    def atype(self) -> Any | None: ...
    @property
    def dimensions(self) -> int | None: ...
    @property
    def default(self) -> int | None: ...
    @property
    def npairs(self) -> int | None: ...
    @property
    def pairs(self) -> list[Any] | None: ...
    @property
    def low(self) -> int | None: ...
    @property
    def high(self) -> int | None: ...
    @property
    def offsets(self) -> list[int] | None: ...

class SourceFileAttr:
    @property
    def attribute_name_index(self) -> int: ...
    @property
    def attribute_length(self) -> int: ...
    @property
    def sourcefile_index(self) -> int: ...

class CodeAttr:
