    @property
    def attributes(self) -> list[Any]: ...

class FieldInfo:
    @property
    def access_flags(self) -> Any: ...
    @property
    def name_index(self) -> int: ...
    @property
    def descriptor_index(self) -> int: ...
    @property
    def attributes_count(self) -> int: ...
    @property
    def attributes(self) -> list[Any]: ...

class MethodInfo:
    @property
    def access_flags(self) -> Any: ...
    @property
    def name_index(self) -> int: ...
    @property
    def descriptor_index(self) -> int: ...
    @property
    def attributes_count(self) -> int: ...
    @property
    def attributes(self) -> list[Any]: ...

class ClassFile:
    @property
    def magic(self) -> int: ...
    @property
    def minor_version(self) -> int: ...
    @property
    def major_version(self) -> int: ...
    @property
    def constant_pool_count(self) -> int: ...
    @property
    def constant_pool(self) -> list[Any | None]: ...
    @property
    def access_flags(self) -> Any: ...
    @property
    def this_class(self) -> int: ...
    @property
    def super_class(self) -> int: ...
    @property
    def interfaces_count(self) -> int: ...
    @property
    def interface_count(self) -> int: ...
    @property
    def interfaces(self) -> list[int]: ...
    @property
    def fields_count(self) -> int: ...
    @property
    def field_count(self) -> int: ...
    @property
    def fields(self) -> list[FieldInfo]: ...
    @property
    def methods_count(self) -> int: ...
    @property
    def method_count(self) -> int: ...
    @property
    def methods(self) -> list[MethodInfo]: ...
    @property
    def attributes_count(self) -> int: ...
    @property
    def attribute_count(self) -> int: ...
    @property
    def attributes(self) -> list[Any]: ...
    def to_bytes(self) -> bytes: ...

class ClassReader:
    @classmethod
    def from_bytes(cls, bytes_or_bytearray: bytes | bytearray) -> ClassReader: ...
    @classmethod
    def from_file(cls, path: str | Path) -> ClassReader: ...
    @property
    def class_info(self) -> ClassFile: ...

class ClassWriter:
    @staticmethod
    def write(classfile: ClassFile) -> bytes: ...

def backend_info() -> tuple[str, str, list[str]]: ...
