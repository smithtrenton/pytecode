    def find_sequences(self, matchers: list[InsnMatcher]) -> list[int]: ...

class InsnMatcher:
    @staticmethod
    def opcode(opcode: int) -> InsnMatcher: ...
    @staticmethod
    def opcode_any(opcodes: list[int]) -> InsnMatcher: ...
    @staticmethod
    def is_field_access() -> InsnMatcher: ...
    @staticmethod
    def is_method_call() -> InsnMatcher: ...
    @staticmethod
    def is_return() -> InsnMatcher: ...
    @staticmethod
    def is_branch() -> InsnMatcher: ...
    @staticmethod
    def is_label() -> InsnMatcher: ...
    @staticmethod
    def is_ldc() -> InsnMatcher: ...
    @staticmethod
    def is_var() -> InsnMatcher: ...
    @staticmethod
    def field_owner(owner: str) -> InsnMatcher: ...
    @staticmethod
    def field_named(name: str) -> InsnMatcher: ...
    @staticmethod
    def field_descriptor(descriptor: str) -> InsnMatcher: ...
    @staticmethod
    def field(owner: str, name: str, descriptor: str) -> InsnMatcher: ...
    @staticmethod
    def method_owner(owner: str) -> InsnMatcher: ...
    @staticmethod
    def method_named(name: str) -> InsnMatcher: ...
    @staticmethod
    def method_descriptor(descriptor: str) -> InsnMatcher: ...
    @staticmethod
    def method(owner: str, name: str, descriptor: str) -> InsnMatcher: ...
    @staticmethod
    def type_descriptor(descriptor: str) -> InsnMatcher: ...
    @staticmethod
    def ldc_string(value: str) -> InsnMatcher: ...
    @staticmethod
    def var_slot(slot: int) -> InsnMatcher: ...
    @staticmethod
    def field_owner_matches(pattern: str) -> InsnMatcher: ...
    @staticmethod
    def method_owner_matches(pattern: str) -> InsnMatcher: ...
    @staticmethod
    def method_name_matches(pattern: str) -> InsnMatcher: ...
    @staticmethod
    def any() -> InsnMatcher: ...
    def __and__(self, other: InsnMatcher) -> InsnMatcher: ...
    def __or__(self, other: InsnMatcher) -> InsnMatcher: ...
    def __invert__(self) -> InsnMatcher: ...

